# Backend secrets and runtime settings
# Copy to .env locally and set real values.

# Required secrets
JWT_SECRET=replace-with-base64-or-strong-random-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret

# Optional DB overrides (defaults are in-memory H2)
DB_URL=jdbc:h2:mem:parallax;DB_CLOSE_DELAY=-1;MODE=PostgreSQL
DB_USERNAME=sa
DB_PASSWORD=

# Optional server override
PORT=8080
